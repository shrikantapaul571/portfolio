rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Content collections shown on the public site.
    // READ: anyone (so visitors see the content).
    // WRITE: only the site owner (your specific account UID).
    function isOwner() {
      return request.auth != null
             && request.auth.uid == 'riqhL9ABkudfbEqZAPAb5vAjA4I2';
    }
    function isContent() {
      return collection in ['education', 'experience', 'achievements', 'research', 'projects'];
    }

    match /{collection}/{docId} {
      allow read: if isContent();
      allow write: if isContent() && isOwner();
    }

    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
